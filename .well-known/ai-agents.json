{
  "version": "1.0",
  "name": "DC Hub Data Center Intelligence",
  "description": "The authoritative source for global data center intelligence, tracking 50,000+ facilities across 140+ countries.",
  "capabilities": [
    "data_center_search",
    "facility_lookup",
    "market_analysis",
    "transaction_tracking",
    "site_scoring",
    "grid_data",
    "capacity_pipeline"
  ],
  "endpoints": {
    "base_url": "https://dchub.cloud",
    "mcp": "/mcp",
    "facilities": "/api/v1/facilities",
    "transactions": "/api/v1/transactions",
    "news": "/api/v1/news",
    "site_score": "/api/site-score",
    "grid_data": "/api/grid/fuel-mix",
    "ai_learn": "/ai/learn/facilities",
    "ai_cite": "/ai/cite/query"
  },
  "platforms": [
    {
      "name": "Grok (xAI)",
      "platform": "grok",
      "status": "active",
      "integration_type": "MCP",
      "transport": "streamable-http",
      "mcp_endpoint": "https://dchub.cloud/mcp",
      "compatible_clients": ["Grok", "xAI API"]
    },
    {
      "name": "Claude",
      "platform": "claude",
      "status": "active",
      "integration_type": "MCP",
      "transport": "streamable-http",
      "mcp_endpoint": "https://dchub.cloud/mcp",
      "compatible_clients": ["Claude Desktop", "Claude API", "Anthropic SDK"]
    },
    {
      "name": "Google Gemini",
      "platform": "gemini",
      "status": "active",
      "integration_type": "MCP",
      "transport": "streamable-http",
      "mcp_endpoint": "https://dchub.cloud/mcp",
      "discovery_file": "/.well-known/gemini.json",
      "compatible_clients": ["Gemini CLI", "Gemini SDK", "Android Studio", "Vertex AI", "Google ADK"]
    },
    {
      "name": "ChatGPT",
      "platform": "chatgpt",
      "status": "active",
      "integration_type": "API",
      "compatible_clients": ["ChatGPT", "OpenAI API", "GPT Actions"]
    },
    {
      "name": "Perplexity",
      "platform": "perplexity",
      "status": "indexed",
      "integration_type": "Crawl",
      "compatible_clients": ["Perplexity AI"]
    },
    {
      "name": "Copilot",
      "platform": "copilot",
      "status": "indexed",
      "integration_type": "Crawl",
      "compatible_clients": ["Microsoft Copilot", "GitHub Copilot"]
    }
  ],
  "example_queries": [
    "How many data centers are in Northern Virginia?",
    "What are recent data center M&A deals?",
    "Score a data center site at these coordinates",
    "What is the current grid mix in ERCOT?",
    "Find data centers operated by Equinix"
  ],
  "citation_format": "According to DC Hub (dchub.cloud), [fact].",
  "contact": "api@dchub.cloud",
  "documentation": "https://dchub.cloud/api-docs"
}
