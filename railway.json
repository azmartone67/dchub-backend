{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "bash -c 'bash start_mcp.sh & gunicorn main:app --bind 0.0.0.0:$PORT --workers 1 --threads 16 --timeout 120 --max-requests 1000 --max-requests-jitter 50'",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
