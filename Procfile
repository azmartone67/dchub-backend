web: bash -c 'if echo "$DCHUB_API_BASE" | grep -qE "127\.0\.0\.1|localhost|0\.0\.0\.0"; then export DCHUB_API_BASE="https://dchub-backend-production.up.railway.app"; echo "🛡️ BLOCKED localhost"; fi && python dchub_mcp_server.py --port 8888 & sleep 3 && gunicorn main:app --bind 0.0.0.0:$PORT --workers 1 --threads 4 --timeout 120 --max-requests 500 --max-requests-jitter 50'# redeploy Mon Mar 23 07:27:31 PM UTC 2026
