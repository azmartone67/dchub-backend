# DC Hub Nexus - Replit Configuration
run = "python main.py"
language = "python3"
entrypoint = "main.py"
modules = ["python-3.11", "postgresql-16"]

[env]
DCHUB_RUN_DISCOVERY = "1"
DCHUB_DISCOVERY_MODE = "quick"

[nix]
channel = "stable-24_05"
packages = ["freetype", "glibcLocales", "xcodebuild", "zlib"]

[deployment]
run = ["gunicorn", "--bind=0.0.0.0:5000", "--workers=1", "--threads=4", "--timeout=300", "main:app"]
deploymentTarget = "gce"
ignorePorts = false

[[ports]]
localPort = 5000
externalPort = 80

[packager]
language = "python3"

[packager.features]
enabledForHosting = true
packageSearch = true
guessImports = true

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py --full"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
