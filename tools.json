          "type": "string",
          "description": "Filter by deal type",
          "enum": ["acquisition", "investment", "merger"]
        }
      },
      "required": []
    },
    "response_shape": {
      "success": "boolean",
      "transactions": [
        {
          "title": "string",
          "buyer": "string",
          "seller": "string",
          "deal_value": "string",
          "deal_type": "string",
          "date": "string (ISO date)",
          "facilities_count": "integer",
          "markets": ["string"]
        }
      ]
    }
  },
  {
    "name": "get_market_intel",
    "description": "Market vacancy rates, pricing trends, inventory data across 35+ tracked markets. Can list all markets, get details for one, or compare multiple side-by-side.",
    "endpoint": "GET /api/v1/markets/list OR /api/v1/markets/{market_name} OR /api/v1/markets/compare?markets=a,b,c",
    "parameters": {
      "type": "object",
      "properties": {
        "market_name": {
          "type": "string",
          "description": "Specific market slug for detail view (e.g., 'northern-virginia', 'dallas', 'phoenix')"
        },
        "compare": {
          "type": "string",
          "description": "Comma-separated market names for side-by-side comparison"
        }
      },
      "required": []
    },
    "response_shape": {
      "name": "string",
      "slug": "string",
      "facility_count": "integer",
      "total_mw": "number",
      "vacancy_rate": "number",
      "avg_price_per_kw": "number",
      "pipeline_mw": "number",
      "primary_utilities": ["string"]
    }
  },
