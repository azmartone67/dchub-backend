[
  {
    "name": "search_facilities",
    "description": "Search 20,000+ data center facilities by name, provider, city, market, or country. Returns facility details including location, power capacity, tier level, and status.",
    "endpoint": "GET /api/agent/facilities",
    "parameters": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query — matches name, city, provider, or market (e.g., 'Equinix', 'Dallas', 'CyrusOne')"
        },
        "country": {
          "type": "string",
          "description": "Filter by country name or code (e.g., 'US', 'United States', 'UK')"
        },
        "limit": {
          "type": "integer",
          "description": "Max results to return (default: 20, max: 100)",
          "default": 20
        }
      },
      "required": []
    },
    "response_shape": {
      "success": "boolean",
      "count": "integer",
      "facilities": [
        {
          "name": "string",
          "provider": "string",
          "city": "string",
          "state": "string",
          "country": "string",
          "market": "string",
          "latitude": "number",
          "longitude": "number",
          "total_power_mw": "number",
          "gross_sqft": "integer",
          "tier_level": "string",
          "status": "string (operational | under_construction | planned)"
        }
      ]
    }
  },
  {
    "name": "get_facility",
    "description": "Get detailed information about a specific data center facility including power, connectivity, certifications, and nearby infrastructure.",
    "endpoint": "GET /api/agent/facilities (with specific facility name in q parameter)",
    "parameters": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Specific facility name (e.g., 'Equinix SV5', 'QTS Atlanta')"
        }
      },
      "required": ["q"]
    }
  },
  {
    "name": "list_transactions",
    "description": "Browse M&A deals — $51B+ tracked with buyer, seller, deal value, date, deal type, and affected markets.",
    "endpoint": "GET /api/transactions",
    "parameters": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "integer",
          "description": "Max results (default: 100)",
          "default": 100
        },
