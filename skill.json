{
  "name": "DC Hub Data Center Intelligence",
  "version": "2.0.0",
  "description": "Access the world's most comprehensive data center intelligence platform. Query 50,000+ facilities, track M&A deals, analyze markets, and score sites.",
  "author": "DC Hub",
  "website": "https://dchub.cloud",
  "tags": ["data-centers", "infrastructure", "real-estate", "energy", "technology", "M&A", "market-intelligence"],
  "category": "business-intelligence",
  "endpoints": [
    {
      "name": "search_facilities",
      "method": "GET",
      "path": "/api/v1/facilities",
      "description": "Search data center facilities by location, operator, or criteria",
      "parameters": {
        "q": "Search query",
        "country": "Country code",
        "operator": "Operator name",
        "limit": "Results limit"
      }
    },
    {
      "name": "get_transactions",
      "method": "GET",
      "path": "/api/v1/transactions",
      "description": "Get M&A transactions and deals",
      "parameters": {
        "limit": "Results limit",
        "year": "Filter by year"
      }
    },
    {
      "name": "score_site",
      "method": "GET",
      "path": "/api/site-score",
      "description": "Score a potential data center site",
      "parameters": {
        "lat": "Latitude",
        "lon": "Longitude",
        "state": "US state code"
      }
    },
    {
      "name": "get_grid_data",
      "method": "GET",
      "path": "/api/grid/fuel-mix",
      "description": "Get real-time grid fuel mix data",
      "parameters": {
        "iso": "ISO/RTO code (ERCOT, PJM, CAISO, etc.)"
      }
    },
    {
      "name": "ai_query",
      "method": "GET",
      "path": "/ai/cite/query",
      "description": "Get AI-ready answers with citations",
      "parameters": {
        "q": "Natural language question"
      }
    }
  ],
  "examples": [
    {
      "query": "How many data centers are there in Dallas?",
      "endpoint": "search_facilities",
      "params": {"q": "Dallas"}
    },
    {
      "query": "What's the latest data center M&A deal?",
      "endpoint": "get_transactions",
      "params": {"limit": 1}
    }
  ],
  "pricing": {
    "free": {"requests_per_day": 100, "features": ["basic_search", "news"]},
    "pro": {"requests_per_day": 10000, "features": ["full_api", "energy_data"]},
    "enterprise": {"requests_per_day": 100000, "features": ["everything", "priority_support"]}
  }
}
