      "extensionOperation": {
        "operationId": "get_pipeline"
      },
      "displayName": "Get Pipeline Data",
      "requestParams": {
        "fields": [
          { "key": "market", "value": { "string_value": "northern-virginia" } },
          { "key": "status", "value": { "string_value": "under-construction" } }
        ]
      },
      "responseParams": {
        "fields": [
          { "key": "total_mw", "value": { "number_value": 5900 } },
          { "key": "projects_count", "value": { "number_value": 47 } }
        ]
      }
    },
