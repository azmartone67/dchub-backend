{
  "mcpServers": {
    "dchub": {
      "type": "streamable-http",
      "url": "https://dchub.cloud/mcp",
      "headers": {
        "X-API-Key": "dchub_gemini_2026_verify"
      },
      "tools": [
        "search_facilities",
        "get_facility",
        "get_market_data",
        "search_deals",
        "get_news",
        "analyze_site"
      ],
      "metadata": {
        "provider": "DC Hub Nexus",
        "version": "2.1.0",
        "tier": "pro",
        "rate_limit": "300 req/min",
        "max_results": 100,
        "docs": "https://dchub.cloud/api-docs"
      }
    }
  }
}
