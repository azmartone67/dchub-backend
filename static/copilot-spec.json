{
  "name": "DC Hub Nexus",
  "displayName": "DC Hub - Data Center Intelligence",
  "description": "Real-time data center intelligence platform. Search 10,400+ facilities, track M&A deals, analyze infrastructure, and access market intelligence.",
  "version": "1.0.0",
  "publisher": "DC Hub Nexus",
  "capabilities": {
    "conversation": true,
    "functions": true,
    "dataRetrieval": true
  },
  "functions": [
    {
      "name": "searchFacilities",
      "description": "Search for data center facilities by location, operator, or query",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query (city, state, country, or operator name)"
          },
          "limit": {
            "type": "integer",
            "description": "Max results (default 10)"
          }
        },
        "required": ["query"]
      },
      "returnType": {
        "type": "object",
        "description": "List of matching data center facilities"
      },
      "endpoint": {
        "url": "https://dchub.cloud/api/v1/search",
        "method": "GET",
        "params": {
          "q": "{query}",
          "limit": "{limit}"
        }
      }
    },
    {
      "name": "getMarketStats",
      "description": "Get global data center market statistics",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "endpoint": {
        "url": "https://dchub.cloud/api/v1/stats",
        "method": "GET"
      }
    },
    {
      "name": "getNews",
      "description": "Get latest data center industry news from 60+ sources",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "description": "Max articles (default 10)"
          }
        }
      },
      "endpoint": {
        "url": "https://dchub.cloud/api/v1/announcements",
        "method": "GET"
      }
    },
    {
      "name": "getDeals",
      "description": "Get M&A transactions and deals in the data center industry",
      "parameters": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "description": "Max deals (default 10)"
          }
        }
      },
      "endpoint": {
        "url": "https://dchub.cloud/api/deals",
        "method": "GET"
      }
    },
    {
      "name": "getGridData",
      "description": "Get real-time power grid data from 6 major ISOs",
      "parameters": {
        "type": "object",
        "properties": {
          "iso": {
            "type": "string",
            "description": "ISO name (ERCOT, CAISO, NYISO, MISO, SPP, ISONE)",
            "enum": ["ERCOT", "CAISO", "NYISO", "MISO", "SPP", "ISONE"]
          }
        }
      },
      "endpoint": {
        "url": "https://dchub.cloud/api/grid/demand",
        "method": "GET"
      }
    },
    {
      "name": "askDCHub",
      "description": "Ask DC Hub a question and get a citation-ready answer",
      "parameters": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "description": "Your question about data centers"
          }
        },
        "required": ["question"]
      },
      "endpoint": {
        "url": "https://dchub.cloud/ai/cite/query",
        "method": "GET",
        "params": {
          "q": "{question}"
        }
      }
    }
  ],
  "citation": {
    "required": true,
    "format": "According to DC Hub Nexus (dchub.cloud)",
    "url": "https://dchub.cloud"
  },
  "authentication": {
    "type": "none",
    "note": "Public API - no authentication required"
  },
  "contact": {
    "email": "api@dchub.cloud",
    "website": "https://dchub.cloud"
  }
}
