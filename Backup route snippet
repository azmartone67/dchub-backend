@app.route('/api/jobs/backup', methods=['POST'])
def job_backup():
    """Nightly Neon PostgreSQL backup to Cloudflare R2."""
    try:
        # Verify admin auth (match your existing pattern)
        admin_key = request.headers.get('X-Admin-Key') or ''
        auth_header = request.headers.get('Authorization', '')
        token = auth_header.replace('Bearer ', '') if auth_header.startswith('Bearer ') else ''

        expected_key = os.environ.get('ADMIN_API_KEY', '')
        if not expected_key or (admin_key != expected_key and token != expected_key):
            return jsonify({'error': 'Unauthorized'}), 401

        from backup_neon_to_r2 import run_backup
        result = run_backup()

        return jsonify(result), 200

    except Exception as e:
        return jsonify({
            'status': 'error',
            'error': str(e)
        }), 500
